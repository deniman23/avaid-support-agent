# --- Режим БД ---
# mock: docker compose -f docker-compose.support.yml (локальный Postgres :5433)
# prod: docker compose -f docker-compose.prod.yml (только db-api → внешняя БД)
USE_MOCK_DB=1

# PostgreSQL (mock или prod). Для prod — URL с ролью support_writer (см. shared/db/init-support-writer.sql)
DATABASE_URL=postgresql://support_writer:support_writer_pass@support-db:5432/avaid_support
# Пример prod (замените host, db, пароль):
# DATABASE_URL=postgresql://support_writer:SECRET@10.0.0.5:5432/my_project

# readonly — только чтение; readwrite — PATCH рубильников и привязки товаров
DB_API_MODE=readwrite

POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=avaid_support

# db-api
SUPPORT_API_KEY=change-me-local-dev-key
DB_API_HOST=0.0.0.0
DB_API_PORT=8090

# Dify HTTP tools (not in LLM prompt)
DIFY_DB_API_URL=http://support-db-api:8090
DIFY_DOCKER_NETWORK=docker_default

# Dify login (для dify-sync-to-studio.py)
# DIFY_EMAIL=
# DIFY_PASSWORD=

# LLM провайдер (если используешь API вместо Ollama)
# Mistral: получить ключ на console.mistral.ai (работает с РФ серверов)
MISTRAL_API_KEY=your-mistral-api-key-here
SUPPORT_LLM_MODEL=mistral-large-latest
